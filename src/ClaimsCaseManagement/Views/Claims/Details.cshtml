@model Claim
@{
    ViewData["Title"] = $"Claim {Model.ClaimNumber}";
}

<h1>Claim @Model.ClaimNumber</h1>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Claimant</dt>
            <dd class="col-sm-8">@Model.Claimant.FirstName @Model.Claimant.LastName (@Model.Claimant.Email)</dd>

            <dt class="col-sm-4">Policy</dt>
            <dd class="col-sm-8">@Model.Policy.PolicyNumber - @Model.Policy.PolicyType (@Model.Policy.CoverageAmount.ToString("C") cover)</dd>

            <dt class="col-sm-4">Adjuster</dt>
            <dd class="col-sm-8">@(Model.Adjuster?.Name ?? "Unassigned")</dd>

            <dt class="col-sm-4">Date of Loss</dt>
            <dd class="col-sm-8">@Model.DateOfLoss.ToString("d")</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Status</span></dd>

            <dt class="col-sm-4">Estimated Amount</dt>
            <dd class="col-sm-8">@Model.EstimatedAmount.ToString("C")</dd>

            <dt class="col-sm-4">Approved Amount</dt>
            <dd class="col-sm-8">@(Model.ApprovedAmount?.ToString("C") ?? "—")</dd>
        </dl>
        <p>@Model.Description</p>
    </div>

    <div class="col-md-6">
        <h5>Change Status</h5>
        <form method="post" asp-action="ChangeStatus">
            <input type="hidden" name="claimId" value="@Model.ClaimId" />
            <div class="mb-2">
                <select name="newStatus" class="form-select">
                    @foreach (var status in Enum.GetValues<ClaimStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
            <div class="mb-2">
                <input type="text" name="comment" class="form-control" placeholder="Comment (optional)" />
            </div>
            <button type="submit" class="btn btn-primary">Update Status</button>
        </form>

        <h5 class="mt-4">Status History</h5>
        <ul class="list-group">
        @foreach (var h in Model.StatusHistory.OrderByDescending(h => h.ChangedAt))
        {
            <li class="list-group-item">
                @h.OldStatus &rarr; @h.NewStatus by @h.ChangedBy on @h.ChangedAt.ToString("g")
                @if (!string.IsNullOrEmpty(h.Comment)) { <div class="text-muted">@h.Comment</div> }
            </li>
        }
        </ul>

        @{
            var recentlyViewed = (List<string>)(ViewBag.RecentlyViewed ?? new List<string>());
        }
        @if (recentlyViewed.Count > 1)
        {
            <h5 class="mt-4">Recently Viewed</h5>
            <ul class="list-group">
            @foreach (var claimNumber in recentlyViewed)
            {
                <li class="list-group-item @(claimNumber == Model.ClaimNumber ? "active" : "")">@claimNumber</li>
            }
            </ul>
        }
    </div>
</div>

<hr />
<h5>Attachments</h5>
<form method="post" asp-action="Upload" enctype="multipart/form-data" class="row g-2 mb-3">
    <input type="hidden" name="claimId" value="@Model.ClaimId" />
    <div class="col-md-8"><input type="file" name="file" class="form-control" required /></div>
    <div class="col-md-2"><button type="submit" class="btn btn-secondary w-100">Upload</button></div>
</form>
<ul class="list-group mb-4">
@foreach (var attachment in Model.Attachments.OrderByDescending(a => a.UploadedAt))
{
    <li class="list-group-item">
        <a asp-action="Download" asp-route-attachmentId="@attachment.ClaimAttachmentId">@attachment.FileName</a>
        <span class="text-muted">(@attachment.UploadedAt.ToString("g"))</span>
    </li>
}
</ul>

<h5>Notes</h5>
<form method="post" asp-action="AddNote" class="row g-2 mb-3">
    <input type="hidden" name="claimId" value="@Model.ClaimId" />
    <div class="col-md-3"><input type="text" name="author" class="form-control" placeholder="Your name" /></div>
    <div class="col-md-7"><input type="text" name="text" class="form-control" placeholder="Note" /></div>
    <div class="col-md-2"><button type="submit" class="btn btn-secondary w-100">Add</button></div>
</form>
<ul class="list-group">
@foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedAt))
{
    <li class="list-group-item"><strong>@note.Author</strong>: @note.Text <span class="text-muted">(@note.CreatedAt.ToString("g"))</span></li>
}
</ul>
