@model IEnumerable<Claim>
@{
    ViewData["Title"] = "Claims";
    var report = (ClaimSummaryReport)ViewBag.SummaryReport;
}

<h1>Claims</h1>

<div class="row mb-4">
    <div class="col-md-3"><div class="card p-3"><strong>Total Claims</strong><div class="fs-4">@report.TotalClaims</div></div></div>
    <div class="col-md-3"><div class="card p-3"><strong>Open Claims</strong><div class="fs-4">@report.OpenClaims</div></div></div>
    <div class="col-md-3"><div class="card p-3"><strong>Total Exposure</strong><div class="fs-4">@report.TotalEstimatedExposure.ToString("C")</div></div></div>
    <div class="col-md-3"><div class="card p-3"><strong>Total Approved</strong><div class="fs-4">@report.TotalApprovedAmount.ToString("C")</div></div></div>
</div>

<form method="get" class="mb-3">
    <select name="statusFilter" class="form-select w-auto" onchange="this.form.submit()">
        <option value="">All statuses</option>
        @foreach (var status in Enum.GetValues<ClaimStatus>())
        {
            <option value="@status" selected="@(ViewBag.StatusFilter == status.ToString())">@status</option>
        }
    </select>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Claim #</th>
            <th>Claimant</th>
            <th>Policy</th>
            <th>Adjuster</th>
            <th>Status</th>
            <th>Estimated</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var claim in Model)
    {
        <tr>
            <td>@claim.ClaimNumber</td>
            <td>@claim.Claimant.FirstName @claim.Claimant.LastName</td>
            <td>@claim.Policy.PolicyNumber</td>
            <td>@(claim.Adjuster?.Name ?? "Unassigned")</td>
            <td><span class="badge bg-secondary">@claim.Status</span></td>
            <td>@claim.EstimatedAmount.ToString("C")</td>
            <td><a asp-action="Details" asp-route-id="@claim.ClaimId">View</a></td>
        </tr>
    }
    </tbody>
</table>
